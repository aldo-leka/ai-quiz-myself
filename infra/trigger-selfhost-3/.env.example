TRIGGER_VERSION=v4.4.3
TRIGGER_PUBLIC_URL=https://trigger.example.com

# Keep these stable after first boot unless you are deliberately rebuilding the stack.
# These credentials are embedded into internal service URLs, so keep them URL-safe.
# Avoid raw reserved characters like /, @, :, ?, and # unless you know you will encode them.
TRIGGER_POSTGRES_USER=trigger
TRIGGER_POSTGRES_PASSWORD=change-me
TRIGGER_POSTGRES_DB=trigger

TRIGGER_CLICKHOUSE_USER=trigger
TRIGGER_CLICKHOUSE_PASSWORD=change-me

# Generate each with: openssl rand -hex 16
TRIGGER_SESSION_SECRET=replace-me
TRIGGER_MAGIC_LINK_SECRET=replace-me
TRIGGER_ENCRYPTION_KEY=replace-me
TRIGGER_MANAGED_WORKER_SECRET=replace-me

TRIGGER_OBJECT_STORE_ACCESS_KEY_ID=trigger-minio
TRIGGER_OBJECT_STORE_SECRET_ACCESS_KEY=change-me
TRIGGER_MINIO_ROOT_USER=trigger-minio
TRIGGER_MINIO_ROOT_PASSWORD=change-me

# GHCR PAT with at least read:packages and write:packages.
TRIGGER_DOCKER_REGISTRY_URL=ghcr.io
TRIGGER_DOCKER_REGISTRY_NAMESPACE=your-github-user-or-org
TRIGGER_DOCKER_REGISTRY_USERNAME=your-github-user
TRIGGER_DOCKER_REGISTRY_PASSWORD=ghp_replace_me

# Leave these alone unless you know exactly why you are changing them.
TRIGGER_WORKLOAD_API_DOMAIN=supervisor
TRIGGER_WORKLOAD_API_PROTOCOL=http
TRIGGER_WORKLOAD_API_PORT_EXTERNAL=8020

NODE_MAX_OLD_SPACE_SIZE=4096
EMAIL_TRANSPORT=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
FROM_EMAIL=
REPLY_TO_EMAIL=
WHITELISTED_EMAILS=
ADMIN_EMAILS=
RESEND_API_KEY=

TRIGGER_AUTH_GITHUB_CLIENT_ID=
TRIGGER_AUTH_GITHUB_CLIENT_SECRET=

DOCKER_AUTOREMOVE_EXITED_CONTAINERS=1
DEBUG=0

# Keep the webapp private; put Caddy/Nginx/Traefik in front of it.
WEBAPP_BIND_ADDRESS=127.0.0.1
WEBAPP_PORT=3000

TRIGGER_INTERNAL_NETWORK=trigger-selfhost-internal

TRIGGER_VOLUME_SHARED=trigger_shared
TRIGGER_VOLUME_POSTGRES=trigger_postgres
TRIGGER_VOLUME_REDIS=trigger_redis
TRIGGER_VOLUME_CLICKHOUSE=trigger_clickhouse
TRIGGER_VOLUME_MINIO=trigger_minio
