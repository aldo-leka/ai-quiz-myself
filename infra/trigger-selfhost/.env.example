# Public URL
TRIGGER_PUBLIC_URL=https://trigger.example.com

# Stable database credentials. Do not rotate these casually after first boot.
TRIGGER_POSTGRES_USER=trigger
TRIGGER_POSTGRES_PASSWORD=change-this-postgres-password
TRIGGER_POSTGRES_DB=trigger

# Stable ClickHouse credentials.
TRIGGER_CLICKHOUSE_USER=trigger
TRIGGER_CLICKHOUSE_PASSWORD=change-this-clickhouse-password

# Trigger secrets. Generate each with: openssl rand -hex 16
TRIGGER_SESSION_SECRET=replace-me
TRIGGER_MAGIC_LINK_SECRET=replace-me
TRIGGER_ENCRYPTION_KEY=replace-me
TRIGGER_MANAGED_WORKER_SECRET=replace-me

# Object storage. For the simple single-VPS setup, keep these aligned with MinIO.
TRIGGER_OBJECT_STORE_ACCESS_KEY_ID=trigger-minio
TRIGGER_OBJECT_STORE_SECRET_ACCESS_KEY=change-this-object-store-password
TRIGGER_MINIO_ROOT_USER=trigger-minio
TRIGGER_MINIO_ROOT_PASSWORD=change-this-minio-root-password

# External image registry. GHCR is the easiest option on a VPS.
# Create a GitHub token with at least write:packages and read:packages.
TRIGGER_DOCKER_REGISTRY_URL=ghcr.io
TRIGGER_DOCKER_REGISTRY_NAMESPACE=your-github-user-or-org
TRIGGER_DOCKER_REGISTRY_USERNAME=your-github-user
TRIGGER_DOCKER_REGISTRY_PASSWORD=ghp_replace_me

# Optional tuning
NODE_MAX_OLD_SPACE_SIZE=4096

# Leave EMAIL_TRANSPORT blank to log magic links in the webapp logs.
# Set it to smtp or resend only after you add the matching provider settings.
EMAIL_TRANSPORT=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=
FROM_EMAIL=
REPLY_TO_EMAIL=
WHITELISTED_EMAILS=
ADMIN_EMAILS=
RESEND_API_KEY=

# Optional GitHub OAuth login.
# In GitHub, create an OAuth App with:
# Homepage URL: https://trigger.example.com
# Authorization callback URL: https://trigger.example.com/auth/github/callback
TRIGGER_AUTH_GITHUB_CLIENT_ID=
TRIGGER_AUTH_GITHUB_CLIENT_SECRET=
