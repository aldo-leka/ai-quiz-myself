# Database
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require&channel_binding=require
APP_BASE_URL=http://localhost:3000
BETTER_AUTH_SECRET=<your-secret>
SENTRY_AUTH_TOKEN=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# AI host (optional model overrides + encryption secret for stored API keys)
API_KEY_ENCRYPTION_SECRET=
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_MODEL=gemini-3-flash-preview
HOST_OPENAI_MODEL=gpt-5-mini
HOST_ANTHROPIC_MODEL=claude-haiku-4-5
HOST_GOOGLE_MODEL=gemini-3.1-flash-lite-preview
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-5-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_DEFAULT_VOICE=alloy
OPENAI_TTS_WWTBAM_VOICE=ballad
OPENAI_TTS_FORMAT=mp3

# Cloudflare R2
R2_ENDPOINT=
R2_REGION=
R2_BUCKET=
R2_PUBLIC_URL=
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
CLOUDFLARE_API_TOKEN=<your-cloudflare-api-token>

# Email
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAILS=admin@example.com

# Google

# Internal social automation
INTERNAL_SOCIAL_API_TOKEN=<random-secret-for-openclaw>
SOCIAL_RENDER_BASE_URL=http://localhost:3000

# Publer
PUBLER_API_KEY=<publer-api-key>
PUBLER_WORKSPACE_ID=<publer-workspace-id>
PUBLER_INSTAGRAM_ACCOUNT_ID=<instagram-account-id>
PUBLER_FACEBOOK_ACCOUNT_ID=<facebook-account-id>
PUBLER_TIKTOK_ACCOUNT_ID=<tiktok-account-id>

# Optional OpenClaw runner env for scripts/openclaw_social_publish.py
QUIZPLUS_SOCIAL_BASE_URL=https://quizplus.io
QUIZPLUS_SOCIAL_PIPELINE_SLUG=organic_publer_main
QUIZPLUS_SOCIAL_SSH_HOST=<vps-tailscale-host-or-ip>
QUIZPLUS_SOCIAL_SSH_USER=<ssh-user>
QUIZPLUS_SOCIAL_SSH_PASSWORD=<ssh-password>
QUIZPLUS_SOCIAL_SSH_PORT=22
QUIZPLUS_SOCIAL_SSH_REMOTE_HOST=127.0.0.1
QUIZPLUS_SOCIAL_SSH_REMOTE_PORT=443
QUIZPLUS_SOCIAL_INSECURE_TLS=1
CRON_SECRET=<same-value-as-internal-social-api-token>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Trigger.dev
TRIGGER_API_URL=
TRIGGER_SECRET_KEY=

# Stripe (usage billing / wallet top-ups)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_CURRENCY=eur
